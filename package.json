{
  "name": "91cost_dynamic",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.1.0"
  },
  "volta": {
    "node": "22.12.0",
    "npm": "10.9.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^3.1.4",
      "brace-expansion": "^1.1.13",
      "rollup": "^4.60.2",
      "immutable": "^5.1.5",
      "yaml": "^2.8.3",
      "postcss": "^8.5.10",
      "anymatch>picomatch": "^2.3.2",
      "vite>picomatch": "^4.0.4",
      "@astrojs/internal-helpers>picomatch": "^4.0.4",
      "astro>picomatch": "^4.0.4",
      "mdast-util-to-hast": "^13.2.1"
    }
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development astro dev --mode development",
    "start": "astro dev",
    "build": "astro build && npm run format-html",
    "format-html": "prettier --write \"dist/**/*.html\"",
    "preview": "astro preview",
    "astro": "astro",
    "stg": "cross-env NODE_ENV=staging astro build --mode staging",
    "prod": "cross-env NODE_ENV=production astro build --mode production",
    "lint": "eslint . --ext .js,.mjs,.ts,.jsx,.tsx,.astro",
    "lint:fix": "eslint . --ext .js,.mjs,.ts,.jsx,.tsx,.astro --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:ci": "astro sync && pnpm type-check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build:github": "cross-env PUBLIC_BASE_URL=/91cost_dynamic/ pnpm build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "astro": "^6.1.8",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "sass-embedded": "^1.93.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sentry/node": "^10.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.2",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.5"
  }
}
