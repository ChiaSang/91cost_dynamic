---
// src/pages/index.astro
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import AreaChartCard from '@/components/AreaChart';
import Layout from '@/layouts/Layout.astro';
import type { PageMeta } from '@/lib/constants';

const meta: PageMeta = {
  title: '91cost - 家庭暖通与空气健康平台',
  description: '面向家庭客户和个人用户，提供舒适家居暖通方案、能耗管理与空气质量数据查询服务',
  ogType: 'website',
};

const solutions = [
  {
    title: '家庭空调优化',
    description: '围绕客厅、卧室和全屋空调使用场景，提升舒适度并降低能耗',
    icon: '❄️',
    link: '/solutions',
  },
  {
    title: '家庭能耗监测',
    description: '实时查看家庭用电、用水和设备运行情况，帮助您节能省心',
    icon: '📊',
    link: '/data',
  },
  {
    title: '空气健康监测',
    description: '温湿度、CO2、PM2.5 等指标实时监测与提醒，守护家人呼吸健康',
    icon: '🌬️',
    link: '/data',
  },
  {
    title: '数据共享查询',
    description: '家庭能耗和空气质量数据统一查询，支持手机查看与历史趋势分析',
    icon: '🔗',
    link: '/data',
  },
];

const indoorTemp = 24.5;
const co2Value = 680;
const pm25Value = 18;

const getTemperatureTone = (value: number) => {
  if (value < 20) {
    return {
      card: 'from-sky-600 via-sky-500 to-cyan-400',
      accent: 'bg-sky-300/40',
      value: 'text-sky-50',
      label: 'text-sky-100/85',
      bar: 'from-sky-400 via-cyan-300 to-sky-200',
      marker: 'border-sky-200 bg-sky-200',
      status: '偏冷',
    };
  }

  if (value <= 26) {
    return {
      card: 'from-emerald-600 via-teal-500 to-cyan-400',
      accent: 'bg-emerald-300/40',
      value: 'text-emerald-50',
      label: 'text-emerald-100/85',
      bar: 'from-emerald-400 via-teal-300 to-cyan-300',
      marker: 'border-emerald-200 bg-emerald-200',
      status: '舒适',
    };
  }

  if (value <= 28) {
    return {
      card: 'from-amber-500 via-orange-500 to-rose-400',
      accent: 'bg-amber-300/40',
      value: 'text-white',
      label: 'text-white/85',
      bar: 'from-amber-300 via-orange-300 to-rose-300',
      marker: 'border-amber-100 bg-amber-100',
      status: '偏暖',
    };
  }

  return {
    card: 'from-rose-600 via-pink-500 to-orange-400',
    accent: 'bg-rose-300/40',
    value: 'text-white',
    label: 'text-white/85',
    bar: 'from-rose-300 via-pink-300 to-orange-200',
    marker: 'border-rose-100 bg-rose-100',
    status: '偏热',
  };
};

const getAirTone = (value: number, thresholds: { good: number; warning: number }) => {
  if (value <= thresholds.good) {
    return {
      bar: 'from-emerald-400 via-teal-300 to-cyan-300',
      marker: 'border-emerald-200 bg-emerald-200',
      value: 'text-emerald-600',
      status: '优',
    };
  }

  if (value <= thresholds.warning) {
    return {
      bar: 'from-amber-400 via-orange-300 to-amber-200',
      marker: 'border-amber-200 bg-amber-200',
      value: 'text-amber-600',
      status: '关注',
    };
  }

  return {
    bar: 'from-rose-400 via-pink-300 to-orange-200',
    marker: 'border-rose-200 bg-rose-200',
    value: 'text-rose-600',
    status: '超标',
  };
};

const temperatureTone = getTemperatureTone(indoorTemp);
const co2Tone = getAirTone(co2Value, { good: 800, warning: 1200 });
const pm25Tone = getAirTone(pm25Value, { good: 12, warning: 35 });
const tempPercent = Math.max(0, Math.min(100, Math.round(((indoorTemp - 16) / 16) * 100)));
const co2Percent = Math.max(0, Math.min(100, Math.round((co2Value / 1200) * 100)));
const pm25Percent = Math.max(0, Math.min(100, Math.round((pm25Value / 75) * 100)));
---

