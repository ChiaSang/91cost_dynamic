          <div class='pt-2 text-center'>
            <div class='text-xs tracking-[0.2em] text-slate-400 uppercase'>实时数据接入</div>
            <div class='mt-3 text-4xl font-bold tracking-tight text-slate-900' data-count-up='1000'>0+</div>
